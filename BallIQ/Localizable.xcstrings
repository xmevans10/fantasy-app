    "BallIQ's own formula — there's no standard fantasy game for tennis, so seasons are scored as résumés: wins carry the total, Slams tower over everything." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fórmula propia de BallIQ — no existe un juego de fantasy estándar para tenis, así que las temporadas se puntúan como resúmenes: las victorias suman el total, y los Grand Slams superan todo lo demás."
          }
        }
      }
    },
    "BallIQ's own scoring formula." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fórmula de puntuación propia de BallIQ."
          }
        }
      }
    },
