        }
      }
    },
    "This community puzzle predates formula tagging — its author may have picked the Half-PPR or Standard variant instead." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este acertijo de la comunidad es anterior al etiquetado de fórmulas — es posible que su autor haya elegido la variante Half-PPR o Standard."
          }
        }
      }
    },
    "This is the industry-standard full-PPR formula — the same default scoring used on ESPN, Yahoo, and Sleeper." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
