# Copy to tools/ingest/.env (gitignored) and fill in. Locally the pipeline reads
# this file; in CI these are GitHub Action secrets.

# NBA — free key from https://app.balldontlie.io (optional: without it, the
# pipeline uses the curated real-stat seed in data/nba_seed.csv).
BALLDONTLIE_API_KEY=

# Supabase — required only for --upsert. Use the SERVICE_ROLE key (server-side
# only, NEVER shipped in the app). Find both in the Supabase dashboard:
# Project Settings → API.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
